# =============================================================================
# HDFC Life Insurance Policy Management System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MongoDB Atlas URI (Production) or local MongoDB URI (Development)
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/hdfc_ipms

# =============================================================================
# JWT / AUTHENTICATION
# =============================================================================
# Use a strong, random 256-bit secret. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_256_bits_long_change_in_production
# JWT absolute expiry: 15 minutes (matches session policy)
JWT_EXPIRES_IN=15m

# =============================================================================
# COOKIE CONFIGURATION
# =============================================================================
# Secret for signing cookies
COOKIE_SECRET=your_cookie_signing_secret_change_in_production
# Cookie name
COOKIE_NAME=hdfc_ipms_token
# Cookie secure flag (true in production with HTTPS, false in development)
COOKIE_SECURE=false
# SameSite policy: 'strict' for production, 'lax' for development
COOKIE_SAMESITE=lax

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origin for CORS (your frontend URL)
CLIENT_URL=http://localhost:5173

# =============================================================================
# RATE LIMITING
# =============================================================================
# Max requests per window per IP
RATE_LIMIT_MAX=100
# Rate limit window in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# =============================================================================
# ADMIN SEED CREDENTIALS (Used only for initial seeding - change immediately!)
# =============================================================================
ADMIN_EMAIL=admin@hdfclife.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Administrator
